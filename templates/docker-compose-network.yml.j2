services:
  db:
    container_name: postgres_docker
    image: postgres:latest
    restart: always
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: {{postgres_pass}}
    networks:
      - backend
    healthcheck:
      test: ["CMD-SHELL","pg_isready -U postgres"]
      interval: 10s
      timeout: 5s
      retries: 5 
  web:
    container_name: nginx_docker
    image: nginx:latest
    restart: always
    ports:
      - "8080:80"
    volumes:
      - "{{project_root}}/my-site:/usr/share/nginx/html:ro"
      - "{{project_root}}/nginx.conf:/etc/nginx/conf.d/default.conf:ro"
    networks:
      - frontend
      - backend

networks:
  frontend:
  backend:
