upstream my_cluster {
{% for app_name, app_data in web_services.items() %}
    server localhost:{{ app_data.host_port }};
{% endfor %}
}

server {
    listen 80;
    server_name cluster.cloudtests.work;

    location / {
        proxy_pass http://my_cluster;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }
}