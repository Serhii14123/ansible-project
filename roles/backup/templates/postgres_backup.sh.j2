#!/bin/bash
# Generated by Ansible. DO NOT edit manually.

set -e # Остановить выполнение при ошибке

# Локальные переменные
BACKUP_DIR="{{ backup_postgres_path }}"
DB_NAME="{{ backup_postgres_db_name }}"
DATE=$(date +%Y-%m-%d_%H-%M)
FILE_NAME="${DB_NAME}_${DATE}.sql.gz"

# Удаленные переменные
REMOTE_USER="backup-manager"
REMOTE_HOST="{{ backup_remote_server_ip }}"
REMOTE_DIR="{{ backup_postgres_remote_path }}"
SSH_KEY="/var/lib/postgresql/.ssh/id_ed25519"

# 1. Создаем дамп и сразу сжимаем его (Production standard)
# Используем pg_dump под юзером postgres (скрипт и так будет от него)
pg_dump "$DB_NAME" | gzip > "$BACKUP_DIR/$FILE_NAME"

# 2. Перенос на удаленное хранилище
# Флаг -e позволяет указать путь к конкретному ключу
rsync -avz -e "ssh -i $SSH_KEY -o StrictHostKeyChecking=no" \
    "$BACKUP_DIR/$FILE_NAME" \
    "$REMOTE_USER@$REMOTE_HOST:$REMOTE_DIR/"

# 3. Ротация (удаляем старые локальные бэкапы старше 3 дней, чтобы не забить диск базы)
find "$BACKUP_DIR" -type f -mtime +3 -name "*.sql.gz" -delete

echo "Backup and transfer of $DB_NAME completed at $(date)"